# ── VSA Field ────────────────────────────────────────────────────────────────
# Copy to .env.local and fill in. Never commit the real file.

# Backend API. Defaults to production if unset.
VITE_API_URL=https://vsa-crm-api.onrender.com

# Google Maps JS API key — required by the admin Map, Live and Trail tabs.
# Without it those tabs render blank with no error.
VITE_GMAP_KEY=
